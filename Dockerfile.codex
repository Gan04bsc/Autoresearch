FROM node:22-bookworm

RUN apt-get update && apt-get install -y \
    git \
    jq \
    curl \
    ca-certificates \
    build-essential \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN npm i -g @openai/codex

WORKDIR /work/literature-agent

CMD ["/bin/bash"]